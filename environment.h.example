/**
 * Environment configuration — copy to environment.h and fill in your values.
 *
 *   cp environment.h.example environment.h
 *
 * environment.h is gitignored and will not be committed.
 */

// WiFi credentials
const char *ssid     = "YourSSID";
const char *password = "YourPassword";

// MQTT broker IP address (do not use mDNS hostnames — unreliable on ESP32-S3)
const char *mqtt_server = "192.168.1.100";

// MQTT topic overrides (optional).
// Uncomment and change any topic to match your Home Assistant automation config.
// Defaults are defined in src/MqttTopics.h.
//
// #define TOPIC_WATER_TEMP    "water/temp"
// #define TOPIC_WATER_RECIRC  "water/recirc"
// #define TOPIC_WATER_CMD     "water/recirc/cmd"
// #define TOPIC_FAN_STATE     "fan/bedroom/state"
// #define TOPIC_FAN_CMD       "fan/bedroom/command"
// #define TOPIC_LIGHT_STATE   "fan/bedroom/light"
// #define TOPIC_LIGHT_CMD     "light/bedroom/command"

// NTP time zone configuration
// GMT offset in seconds: UTC-8 = -28800, UTC-7 = -25200, UTC-5 = -18000, UTC+0 = 0
const long tz_offset_sec  = -25200;   // Mountain Standard Time
// Daylight saving time offset in seconds (3600 = 1 hour, 0 = no DST)
const int  dst_offset_sec = 3600;
